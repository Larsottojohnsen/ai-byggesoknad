# ============================================================
# AI Byggesøknad – Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Database ---
POSTGRES_USER=byggesoknad
POSTGRES_PASSWORD=byggesoknad_dev
POSTGRES_DB=byggesoknad
DATABASE_URL=postgresql://byggesoknad:byggesoknad_dev@localhost:5432/byggesoknad

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
OPENAI_STRONG_MODEL=gpt-4.1

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- External APIs ---
# Kartverket / Geonorge – no key required for public APIs
KARTVERKET_API_BASE=https://api.kartverket.no
GEONORGE_API_BASE=https://wfs.geonorge.no
NVE_API_BASE=https://gis3.nve.no

# --- Storage (local for dev) ---
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# --- Feature flags ---
FEATURE_PDF_GENERATION=true
FEATURE_AI_CLASSIFICATION=true
FEATURE_HAZARD_DATA=true
FEATURE_PLAN_DATA=true
